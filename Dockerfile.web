# Dockerfile for the BLACKJAW marketing (Astro static) site
# Build from the monorepo root:
#   docker build --tag web:latest -f ./Dockerfile.web .
#
# Dokploy: Dockerfile Path = Dockerfile.web, Container Port = 3000.

FROM oven/bun:1 AS build

WORKDIR /app

COPY . .

RUN bun install --frozen-lockfile
RUN bun --filter @repo/web build

# ---------- Runtime ----------
FROM oven/bun:1-slim AS runtime

WORKDIR /app

COPY --from=build /app/apps/web/dist ./dist

ENV PORT=3088
EXPOSE 3088

CMD ["bunx", "--bun", "serve", "-s", "dist", "-l", "3088"]
