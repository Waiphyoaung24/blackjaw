---
import '@/styles/globals.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'BLACKJAW — Lifestyle Fitness Apparel',
  description = 'BLACKJAW lifestyle fitness apparel. Shirts, shorts, joggers, and outerwear built for training and street.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/blackjaw/favicon.png" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800;900&family=Nunito+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-white">
    <slot />
  </body>
</html>
