---
const sections = [
  { title: "FAQs", links: ["FAQs","Returns and Exchanges","Contact Us","Terms of Service","General Size Chart","Shipping and Delivery Policy","Privacy Policy","Do Not Sell","GDPR"] },
  { title: "Quick Links", links: ["Search","All Products","Gift Card","Rewards","Shipping Protection"] },
  { title: "About", links: ["Our Story","Customer Reviews","Careers","Account","Store Location"] },
];
---
<footer class="bg-[color:var(--color-surface-alt)] py-16 px-4 lg:px-8">
  <div class="max-w-2xl mx-auto text-center mb-16">
    <h2 class="font-[family-name:var(--font-display)] font-black uppercase text-2xl lg:text-3xl tracking-[0.14em] mb-3">JOIN OUR NEWSLETTER</h2>
    <p class="text-sm text-black/70 mb-6">Sign up for exclusive offers, original stories, events and more.</p>
    <form action="#" onsubmit="return false" class="flex max-w-md mx-auto gap-2">
      <input type="email" placeholder="Enter your email" class="flex-1 px-4 py-3 bg-white border border-black/15 text-sm rounded-full outline-none" />
      <button class="bg-black text-white rounded-full px-6 py-3 text-[11px] tracking-[0.2em] uppercase font-bold hover:opacity-80">SUBSCRIBE</button>
    </form>
  </div>

  <div class="max-w-[1440px] mx-auto grid grid-cols-2 md:grid-cols-4 gap-10 mb-12">
    {sections.map((s) => (
      <div>
        <h4 class="text-[12px] font-[family-name:var(--font-display)] font-bold tracking-[0.16em] uppercase mb-4">{s.title}</h4>
        <ul class="space-y-2">
          {s.links.map((l) => <li><a href="#" class="text-sm text-black/70 hover:text-black">{l}</a></li>)}
        </ul>
      </div>
    ))}
    <div>
      <div class="bg-[#1c1c1c] text-white rounded-xl p-5">
        <div class="flex items-center gap-1 mb-2 text-[#4ade80]">
          {Array.from({length:5}).map(() => (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          ))}
        </div>
        <div class="text-sm font-bold">Over 100,000+ Reviews</div>
        <div class="text-[11px] text-white/60 mb-4">Powered by Loox</div>
      </div>
      <div class="mt-4 space-y-2">
        <a href="#" class="block bg-black text-white text-center rounded-lg px-4 py-2 text-[11px] tracking-[0.16em] uppercase font-bold">App Store</a>
        <a href="#" class="block bg-black text-white text-center rounded-lg px-4 py-2 text-[11px] tracking-[0.16em] uppercase font-bold">Google Play</a>
      </div>
    </div>
  </div>

  <div class="max-w-[1440px] mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 border-t border-black/10 pt-6">
    <p class="text-xs text-black/60">© 2026 BLACKJAW</p>
    <div class="flex items-center gap-4">
      <a href="#" aria-label="Instagram"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg></a>
      <a href="#" aria-label="TikTok"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.5 7.5a5.5 5.5 0 0 1-3.5-1.3v8.3a5.5 5.5 0 1 1-5.5-5.5c.3 0 .6 0 .9.1v2.9a2.6 2.6 0 1 0 1.8 2.5V2h2.8c0 2.5 2 4.5 4.5 4.5v1z"/></svg></a>
    </div>
  </div>
</footer>
