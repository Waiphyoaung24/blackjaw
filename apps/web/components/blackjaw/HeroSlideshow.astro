---
const slides = [
  { desktop: "/blackjaw/hero-1-desktop.jpg", mobile: "/blackjaw/hero-1-mobile.jpg", heading: "RESTOCK", cta: "SHOP NOW", href: "#featured" },
  { desktop: "/blackjaw/hero-2-desktop.jpg", mobile: "/blackjaw/hero-2-mobile.jpg", heading: "NEW DROP", cta: "SHOP NOW", href: "#featured" },
  { desktop: "/blackjaw/hero-3-desktop.jpg", mobile: "/blackjaw/hero-3-desktop.jpg", heading: "RESTOCK", cta: "SHOP NOW", href: "#featured" },
];
---
<section class="relative w-full h-[500px] lg:h-[546px] overflow-hidden bg-black" data-blackjaw-hero>
  {slides.map((s, i) => (
    <div class={`blackjaw-slide absolute inset-0 transition-opacity duration-700 ${i === 0 ? "opacity-100" : "opacity-0"}`} data-idx={i}>
      <picture>
        <source media="(min-width: 768px)" srcset={s.desktop} />
        <img src={s.mobile} alt={s.heading} class="w-full h-full object-cover" />
      </picture>
      <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-black/10 to-transparent"></div>
      <div class="absolute inset-x-0 bottom-16 flex flex-col items-center text-center text-white px-4">
        <span class="text-[11px] uppercase tracking-[0.3em] mb-3">BLACKJAW</span>
        <h1 class="font-[family-name:var(--font-display)] font-black uppercase text-[42px] lg:text-[72px] leading-none tracking-[0.08em]" style="text-shadow:0 2px 12px rgba(0,0,0,.5);">{s.heading}</h1>
        <a href={s.href} class="mt-6 inline-flex items-center justify-center bg-black text-white rounded-full px-10 py-3 text-[11px] tracking-[0.2em] uppercase font-bold hover:bg-white hover:text-black transition-colors">{s.cta}</a>
      </div>
    </div>
  ))}
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-2 z-10">
    {slides.map((_, i) => (
      <button class={`blackjaw-dot w-[6px] h-[6px] rounded-full transition-colors ${i === 0 ? "bg-white" : "bg-white/50"}`} data-idx={i} aria-label={`Slide ${i + 1}`}></button>
    ))}
  </div>
</section>
<div class="relative flex justify-center -mt-6 z-10">
  <a href="#featured" class="w-12 h-12 rounded-full bg-white shadow-md flex items-center justify-center hover:bg-black hover:text-white transition-colors" aria-label="Scroll down">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
  </a>
</div>

<script>
  const root = document.querySelector("[data-blackjaw-hero]");
  if (root) {
    const slides = root.querySelectorAll<HTMLElement>(".blackjaw-slide");
    const dots = root.querySelectorAll<HTMLElement>(".blackjaw-dot");
    let i = 0;
    setInterval(() => {
      slides[i].style.opacity = "0";
      dots[i].classList.replace("bg-white", "bg-white/50");
      i = (i + 1) % slides.length;
      slides[i].style.opacity = "1";
      dots[i].classList.replace("bg-white/50", "bg-white");
    }, 5000);
  }
</script>
