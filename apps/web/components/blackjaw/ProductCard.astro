---
interface Props {
  code: string;
  title: string;
  primaryImg: string;
  secondaryImg: string;
  colors: { name: string; hex: string }[];
  rating: number;
  reviewCount: number;
  isNew?: boolean;
}
const { code, title, primaryImg, secondaryImg, colors, rating, reviewCount, isNew } = Astro.props;
const filledStars = Math.round(rating);
---
<a href="#" class="group block">
  <div class="relative overflow-hidden bg-[color:var(--color-surface-alt)] aspect-[2/3]">
    {isNew && (
      <span class="absolute top-3 left-3 z-10 bg-black text-white text-[9px] tracking-[0.18em] uppercase font-bold px-2 py-1">NEW LAUNCH</span>
    )}
    <img src={primaryImg} alt={title} class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 group-hover:opacity-0" loading="lazy" />
    <img src={secondaryImg} alt={title} class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-300 group-hover:opacity-100" loading="lazy" />
  </div>
  <div class="pt-3 pb-6">
    <h3 class="text-[12px] font-[family-name:var(--font-display)] font-bold tracking-[0.12em] uppercase text-black">{code} {title}</h3>
    <div class="flex items-center gap-1.5 mt-2">
      {colors.slice(0, 6).map((c) => (
        <span class="inline-block w-3 h-3 rounded-full border border-black/15" style={`background:${c.hex}`} title={c.name}></span>
      ))}
    </div>
    <div class="flex items-center gap-1 mt-2 text-black">
      {Array.from({ length: 5 }).map((_, i) => (
        <svg width="11" height="11" viewBox="0 0 24 24" fill={i < filledStars ? "currentColor" : "none"} stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      ))}
      <span class="text-[11px] text-black/60 ml-1">({reviewCount})</span>
    </div>
  </div>
</a>
