---
import ProductCard from "./ProductCard.astro";
import { products } from "@/data/products";
---
<section id="featured" class="py-16 px-4 lg:px-8 max-w-[1440px] mx-auto">
  <h2 class="text-center font-[family-name:var(--font-display)] font-black uppercase text-[22px] lg:text-[28px] tracking-[0.2em] mb-10">
    Featured
  </h2>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
    {products.map((p) => <ProductCard {...p} />)}
  </div>
  <div class="flex justify-center mt-12">
    <a href="#" class="inline-flex items-center gap-2 border border-black rounded-full px-10 py-3 text-[11px] tracking-[0.2em] uppercase font-bold hover:bg-black hover:text-white transition-colors">SEE ALL →</a>
  </div>
</section>
